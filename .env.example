# Claude Superpowers — Environment Configuration
# Copy to .env and fill in your values.

# --- LLM ---
# Primary model routing
CHAT_MODEL=claude                     # chat provider: claude | openai | chatgpt
JOB_MODEL=claude                      # job provider: claude | openai | chatgpt

# ChatGPT/OpenAI fallback (used when Claude fails/unavailable)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                      # Enables automatic ChatGPT/OpenAI fallback when Claude fails
OPENAI_MODEL=gpt-4o                  # Default OpenAI model (set gpt-4o-mini for lower cost)
LLM_FALLBACK=true                    # Set to false to disable auto-fallback

# --- Messaging ---
SLACK_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
DISCORD_BOT_TOKEN=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_PORT=587
SMTP_FROM=

# --- Dashboard ---
DASHBOARD_USER=admin
DASHBOARD_PASS=CHANGEME_GENERATE_A_STRONG_PASSWORD
DASHBOARD_SECRET=               # JWT signing key; auto-generated if empty

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0

# --- Vault ---
VAULT_IDENTITY_FILE=~/.claude-superpowers/vault.key

# --- SSH Fabric ---
# SSH_CONNECT_TIMEOUT=10
# SSH_COMMAND_TIMEOUT=30
SSH_AUTO_ADD_HOST_KEYS=false          # Keep false for strict host verification; set true only for trusted bootstrap flows

# --- Telegram Bot (Phase 9) ---
ALLOWED_CHAT_IDS=                    # Comma-separated allowlist (required for security)
TELEGRAM_SESSION_TTL=3600            # Conversation history TTL in seconds
TELEGRAM_MAX_HISTORY=20              # Max messages per chat session
TELEGRAM_MAX_PER_CHAT=2              # Max concurrent jobs per chat
TELEGRAM_MAX_GLOBAL=5                # Max concurrent jobs globally
TELEGRAM_QUEUE_OVERFLOW=10           # Max queued jobs before rejecting

# --- Telegram Webhook (Phase B) ---
TELEGRAM_MODE=polling                # "webhook" or "polling" (default: polling)
TELEGRAM_WEBHOOK_SECRET=             # Secret token for webhook verification (recommended)
TELEGRAM_WEBHOOK_URL=                # Public HTTPS URL for webhook (e.g. https://bot.example.com/webhook/telegram)
TELEGRAM_ADMIN_CHAT_ID=              # Admin chat ID for access request notifications

# --- Home Automation ---
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
