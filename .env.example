# Claude Superpowers — Environment Configuration
# Copy to .env and fill in your values.

# --- LLM ---
ANTHROPIC_API_KEY=

# --- Messaging ---
SLACK_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
