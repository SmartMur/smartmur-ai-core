# Claude Superpowers — Environment Configuration
# Copy to .env and fill in your values.

# --- LLM ---
ANTHROPIC_API_KEY=

# --- Messaging ---
SLACK_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
DISCORD_BOT_TOKEN=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_PORT=587
SMTP_FROM=

# --- Dashboard ---
DASHBOARD_USER=admin
DASHBOARD_PASS=superpowers

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0

# --- Vault ---
VAULT_IDENTITY_FILE=~/.claude-superpowers/vault.key

# --- SSH Fabric ---
# SSH_CONNECT_TIMEOUT=10
# SSH_COMMAND_TIMEOUT=30

# --- Telegram Bot (Phase 9) ---
ALLOWED_CHAT_IDS=                    # Comma-separated allowlist (required for security)
TELEGRAM_SESSION_TTL=3600            # Conversation history TTL in seconds
TELEGRAM_MAX_HISTORY=20              # Max messages per chat session
TELEGRAM_MAX_PER_CHAT=2              # Max concurrent jobs per chat
TELEGRAM_MAX_GLOBAL=5                # Max concurrent jobs globally
TELEGRAM_QUEUE_OVERFLOW=10           # Max queued jobs before rejecting

# --- Home Automation ---
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
