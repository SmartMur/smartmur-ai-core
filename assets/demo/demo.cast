[5.42, "o", "\r\n"]
[5.44, "o", "Usage: claw [OPTIONS] COMMAND [ARGS]...\r\n"]
[5.46, "o", "\r\n"]
[5.48, "o", "  Claude Superpowers -- autonomous skill execution and orchestration.\r\n"]
[5.5, "o", "\r\n"]
[5.52, "o", "Options:\r\n"]
[5.54, "o", "  --version  Show the version and exit.\r\n"]
[5.56, "o", "  --help     Show this message and exit.\r\n"]
[5.58, "o", "\r\n"]
[5.6, "o", "Commands:\r\n"]
[5.62, "o", "  agent        Discover and run subagents.\r\n"]
[5.64, "o", "  benchmark    Run orchestration performance benchmarks.\r\n"]
[5.66, "o", "  browse       Browser automation -- navigate, screenshot, extract.\r\n"]
[5.68, "o", "  cron         Manage scheduled jobs.\r\n"]
[5.7, "o", "  dag          DAG-based parallel task execution.\r\n"]
[5.72, "o", "  dashboard    Launch the Claw web dashboard.\r\n"]
[5.74, "o", "  intake       Clear context, plan, and dispatch skills.\r\n"]
[5.76, "o", "  jobs         Git-branch job orchestration.\r\n"]
[5.78, "o", "  llm          Manage LLM providers.\r\n"]
[5.8, "o", "  memory       Persistent memory store.\r\n"]
[5.82, "o", "  msg          Send messages via Slack, Telegram, Discord, email.\r\n"]
[5.84, "o", "  orchestrate  Run orchestration commands.\r\n"]
[5.86, "o", "  pack         Manage skill/workflow/agent packs.\r\n"]
[5.88, "o", "  policy       Manage orchestration safety policies.\r\n"]
[5.9, "o", "  release      Manage releases and changelogs.\r\n"]
[5.92, "o", "  report       View and export saved reports.\r\n"]
[5.94, "o", "  skill        Manage and execute skills.\r\n"]
[5.96, "o", "  ssh          Execute commands on remote hosts.\r\n"]
[5.98, "o", "  vault        Manage encrypted secrets.\r\n"]
[6.0, "o", "  watcher      Manage file watchers.\r\n"]
[6.02, "o", "  workflow     Run multi-step workflows.\r\n"]
